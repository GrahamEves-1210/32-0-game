# Copy this file to .env.local and fill in your key
# .env.local is gitignored — never commit your real key

# CollegeBasketballData.com API key
# Sign up at: https://www.collegebasketballdata.com/
VITE_CBB_API_KEY=your_api_key_here

# Base URL — do not change unless the API moves
VITE_CBB_API_BASE=https://api.collegebasketballdata.com
